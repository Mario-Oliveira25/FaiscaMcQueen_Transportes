@model FaiscaMcQueen_Transportes.ViewModels.AtivoViewModel

@{
    ViewData["Title"] = "Adicionar Ativo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0" style="color: var(--brand-primary);">Novo Ativo</h2>
        <p class="text-muted mb-0">Registe um novo veículo ou máquina no sistema.</p>
    </div>
    <a asp-action="Index" class="btn btn-light px-4 py-2 rounded-3 border">
        <i class="bi bi-arrow-left me-2"></i> Voltar
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Matricula" class="form-label fw-semibold text-muted small">Matrícula</label>
                            <input asp-for="Matricula" class="form-control form-control-lg rounded-3" placeholder="Ex: AA-00-00" />
                            <span asp-validation-for="Matricula" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label asp-for="Tipo" class="form-label fw-semibold text-muted small">Tipo de Veículo</label>
                            <input asp-for="Tipo" class="form-control form-control-lg rounded-3" placeholder="Ex: Camião, Máquina" />
                            <span asp-validation-for="Tipo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="Marca" class="form-label fw-semibold text-muted small">Marca</label>
                            <input asp-for="Marca" class="form-control form-control-lg rounded-3" placeholder="Ex: Volvo" />
                            <span asp-validation-for="Marca" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="Modelo" class="form-label fw-semibold text-muted small">Modelo</label>
                            <input asp-for="Modelo" class="form-control form-control-lg rounded-3" placeholder="Ex: FH16" />
                            <span asp-validation-for="Modelo" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-custom px-5 py-2 rounded-3 shadow-sm">
                            <i class="bi bi-check2-circle me-2"></i> Guardar Ativo
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}