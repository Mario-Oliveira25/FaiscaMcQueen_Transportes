@model FaiscaMcQueen_Transportes.ViewModels.AtivoViewModel

@{
    ViewData["Title"] = "Detalhes do Ativo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0" style="color: var(--brand-primary);">Ficha do Ativo</h2>
        <p class="text-muted mb-0">Informação detalhada do veículo.</p>
    </div>
    <div>
        
    
        <a asp-action="Index" class="btn btn-light px-4 py-2 me-2 rounded-3 border">
            <i class="bi bi-arrow-left me-2"></i> Voltar
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4 py-2 rounded-3 shadow-sm me-2 text-dark fw-semibold">
            <i class="bi bi-pencil me-2"></i> Editar
        </a>
    
        <button type="button" class="btn btn-danger px-4 py-2 rounded-3 shadow-sm me-2 fw-semibold" data-bs-toggle="modal" data-bs-target="#modalEliminar">
            <i class="bi bi-trash me-2"></i> Eliminar
        </button>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4 pb-3 border-bottom">
                    <div class="display-1 text-muted mb-3">
                        <i class="bi bi-truck-front"></i>
                    </div>
                    <h3 class="fw-bold" style="color: var(--brand-primary);">@Model?.Marca @Model?.Modelo</h3>
                    <span class="badge bg-light text-dark border px-3 py-2 fs-5 font-monospace mt-2">@Model?.Matricula</span>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0 small">Identificador Interno</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0 text-break text-muted small">@Model?.Id</p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0">Tipo de Ativo</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0 fw-bold">@Model?.Tipo</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0">Marca</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0">@Model?.Marca</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0">Modelo</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0">@Model?.Modelo</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-6 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0" style="color: var(--brand-primary);">Últimas Intervenções</h5>
                <i class="bi bi-clock-history text-muted"></i>
            </div>
        
            <div class="card-body px-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 0.85rem;">
                        <thead class="text-muted">
                            <tr>
                                <th>DATA</th>
                                <th>DESCRIÇÃO</th>
                                <th>TÉCNICO</th>
                                <th class="text-center">ESTADO</th>
                            </tr>
                        </thead>
                        <tbody>
                        
                            <tr>
                                <td class="text-nowrap">15/05/2026</td>
                                <td class="text-truncate" style="max-width: 150px;">Mudança de óleo e filtros da caixa</td>
                                <td class="text-nowrap">Guilherme Buss</td>
                                <td class="text-center">
                                    <span class="badge badge-pendente rounded-pill px-2 py-1">Pendente</span>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-nowrap">10/04/2026</td>
                                <td class="text-truncate" style="max-width: 150px;">Substituição de pastilhas de travão</td>
                                <td class="text-nowrap">Mário Oliveira</td>
                                <td class="text-center">
                                    <span class="badge badge-em-curso rounded-pill px-2 py-1">Em Curso</span>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-nowrap">22/01/2026</td>
                                <td class="text-truncate" style="max-width: 150px;">Revisão anual obrigatória</td>
                                <td class="text-nowrap">Jorge Dias</td>
                                <td class="text-center">
                                    <span class="badge badge-concluido rounded-pill px-2 py-1">Concluído</span>
                                </td>
                            </tr>
                            @*
                        @if (Model.UltimasIntervencoes != null && Model.UltimasIntervencoes.Any())
                        {
                            foreach (var inter in Model.UltimasIntervencoes)
                            {
                                <tr>
                                    <td class="text-nowrap">@inter.Data.ToString("dd/MM/yyyy")</td>
                                    <td class="text-truncate" style="max-width: 150px;">@inter.Descricao</td>
                                    <td class="text-center">
                                        @{
                                            string badgeClass = inter.Estado switch
                                            {
                                                "Pendente" => "badge-pendente",
                                                "Em Curso" => "badge-em-curso",
                                                "Concluído" => "badge-concluido",
                                                _ => "bg-secondary text-white"
                                            };
                                        }
                                        <span class="badge @badgeClass rounded-pill px-2 py-1">@inter.Estado</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">
                                    <i class="bi bi-patch-check fs-3 mb-2 d-block"></i>
                                    Nenhuma intervenção registada.
                                </td>
                            </tr>
                        }
                        *@
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-3 pt-3 border-top">
                    <a asp-controller="Intervencoes" asp-action="Index" asp-route-ativoId="@Model?.Id" class="btn btn-sm btn-link text-decoration-none fw-semibold" style="color: var(--brand-action);">
                        Ver Histórico Completo &rarr;
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            
            <div class="modal-header border-bottom-0 pb-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-danger" id="modalEliminarLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Confirmar Eliminação
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            
            <div class="modal-body px-4 py-3">
                <p class="mb-1 text-muted">Tem a certeza que pretende eliminar este registo?</p>
                
                <p class="text-danger small fw-semibold mb-0 mt-3">Aviso: Esta ação é irreversível.</p>
            </div>
            
            <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Cancelar</button>
                
                <form asp-action="Delete" asp-controller="Ativos" method="post">
                    <input type="hidden" name="id" value="@Model?.Id" />
                    <button type="submit" class="btn btn-danger rounded-3 px-4 fw-semibold">
                        Sim, Eliminar Ativo
                    </button>
                </form>
            </div>
            
        </div>
    </div>
</div>