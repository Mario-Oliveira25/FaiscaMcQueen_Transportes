@model FaiscaMcQueen_Transportes.Data.FaiscaMcQueen.Ativo

@{
    ViewData["Title"] = "Detalhes do Ativo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0" style="color: var(--brand-primary);">Ficha do Ativo</h2>
        <p class="text-muted mb-0">Informação detalhada do veículo.</p>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4 py-2 rounded-3 shadow-sm me-2 text-dark fw-semibold">
            <i class="bi bi-pencil me-2"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-light px-4 py-2 rounded-3 border">
            <i class="bi bi-arrow-left me-2"></i> Voltar
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4 pb-3 border-bottom">
                    <div class="display-1 text-muted mb-3">
                        <i class="bi bi-truck-front"></i>
                    </div>
                    <h3 class="fw-bold" style="color: var(--brand-primary);">@Model.Marca @Model.Modelo</h3>
                    <span class="badge bg-light text-dark border px-3 py-2 fs-5 font-monospace mt-2">@Model.Matricula</span>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0 small">Identificador Interno</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0 text-break text-muted small">@Model.Id</p>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0">Tipo de Ativo</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0 fw-bold">@Model.Tipo</p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0">Marca</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0">@Model.Marca</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-5">
                        <p class="fw-semibold text-muted mb-0">Modelo</p>
                    </div>
                    <div class="col-sm-7">
                        <p class="mb-0">@Model.Modelo</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-6 mt-4 mt-lg-0">
        <div class="card border-0 shadow-sm rounded-4 h-100" style="background-color: var(--brand-bg);">
            <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center text-center">
                <i class="bi bi-tools fs-1 text-muted mb-3"></i>
                <h5 class="fw-bold" style="color: var(--brand-primary);">Histórico de Intervenções</h5>
                <p class="text-muted small">Aqui poderás listar no futuro todas as intervenções associadas a este ativo (Relação M:N).</p>
                <a asp-controller="Intervencoes" asp-action="Index" class="btn btn-sm btn-outline-secondary mt-2 rounded-pill">Ver todas as Intervenções</a>
            </div>
        </div>
    </div>
</div>