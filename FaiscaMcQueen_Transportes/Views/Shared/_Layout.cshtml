<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TranspoTech</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-header">
            <img src="~/images/logo.png" alt="TranspoTech" class="sidebar-logo">
            </div>

            <ul class="nav nav-pills flex-column">
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Ativos" asp-action="Index">
                        <i class="bi bi-truck"></i> Ativos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Tecnicos" asp-action="Index">
                        <i class="bi bi-people"></i> Técnicos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Intervencoes" asp-action="Index">
                        <i class="bi bi-tools"></i> Intervenções
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Configuracoes" asp-action="Index">
                        <i class="bi bi-gear"></i> Definições
                    </a>
                </li>
            </ul>
        </aside>

        <header class="top-header">
            <div class="user-info">
                <span class="text-muted small">Olá, <b class="text-dark">Utilizador de Teste</b></span>
                <a href="#" class="btn-logout">Sair</a>
            </div>
        </header>

        <main class="main-content">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </main>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>