@page
@model RegisterModel
@{
    ViewData["Title"] = "Criar Conta";
}

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div style="height: 6px; background-color: var(--brand-action);"></div>
            <div class="card-body p-5">
                <div class="mb-4">
                    <h3 class="fw-bold" style="color: var(--brand-primary);">Criar Nova Conta</h3>
                    <p class="text-muted">Preencha os dados para aceder à plataforma.</p>
                </div>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                    
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input asp-for="Input.Email" class="form-control border-0 bg-light" placeholder="nome@exemplo.com" />
                                <label asp-for="Input.Email">Email Profissional</label>
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="Input.Password" class="form-control border-0 bg-light" placeholder="Password" />
                                <label asp-for="Input.Password">Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-floating">
                                <input asp-for="Input.ConfirmPassword" class="form-control border-0 bg-light" placeholder="Confirmar Password" />
                                <label asp-for="Input.ConfirmPassword">Confirmar Password</label>
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-custom rounded-3 shadow-sm py-3 mt-3 fw-bold">Criar Conta</button>
                </form>
            </div>
            <div class="card-footer bg-light border-0 text-center py-3">
                <span class="small text-muted">Já tem uma conta? <a asp-page="./Login" class="text-decoration-none fw-bold" style="color: var(--brand-primary);">Fazer Login</a></span>
            </div>
        </div>
    </div>
</div>