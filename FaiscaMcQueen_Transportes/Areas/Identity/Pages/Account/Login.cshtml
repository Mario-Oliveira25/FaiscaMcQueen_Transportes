@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-6 col-lg-4">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div style="height: 6px; background-color: var(--brand-action);"></div>
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <img src="~/images/logo.png" width="250px" />
                </div>

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control border-0 bg-light" placeholder="nome@exemplo.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control border-0 bg-light" placeholder="Password" />
                        <label asp-for="Input.Password">Password</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-custom rounded-3 shadow-sm py-3 fw-bold">Entrar</button>
                </form>
            </div>
            <div class="card-footer bg-light border-0 text-center py-3">
                <span class="small text-muted">Ainda não tem conta? <a asp-page="./Register" class="text-decoration-none fw-bold" style="color: var(--brand-primary);">Registar</a></span>
            </div>
        </div>
    </div>
</div>